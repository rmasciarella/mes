{
  "name": "@tsu-stack/db",
  "private": true,
  "type": "module",
  "imports": {
    "#@/*": "./src/*.ts"
  },
  "exports": {
    ".": "./src/index.ts",
    "./schema": "./src/schema/index.ts",
    "./repositories": "./src/repositories/index.ts"
  },
  "scripts": {
    "db": "pnpm dotenvx run -f ../env/.env -- drizzle-kit",
    "db:dev:start": "docker compose -f docker-compose.dev.yaml up -d",
    "db:dev:stop": "docker compose -f docker-compose.dev.yaml stop",
    "auth:generate": "vpx https://pkg.pr.new/better-auth/better-auth/@better-auth/cli@6913 generate --config ../auth/src/index.ts --y --output ./src/schema/iam/tables.ts"
  },
  "dependencies": {
    "@tsu-stack/core": "workspace:*",
    "@tsu-stack/logger": "workspace:*",
    "drizzle-orm": "catalog:",
    "nanoid": "catalog:",
    "postgres": "catalog:"
  },
  "devDependencies": {
    "@dotenvx/dotenvx": "catalog:",
    "@tsu-stack/env": "workspace:*",
    "@tsu-stack/tsconfig": "workspace:*",
    "@types/node": "catalog:",
    "drizzle-kit": "catalog:",
    "typescript": "catalog:"
  },
  "peerDependencies": {
    "@tanstack/react-start": "catalog:"
  }
}
